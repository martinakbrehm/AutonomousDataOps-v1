# Exemplo de variáveis de ambiente para desenvolvimento
# Copie este arquivo para .env e preencha os valores necessários

# Chave de API simples para autenticação das requests HTTP (use segredo forte)
APP_API_KEY=changeme_replace_with_strong_key

# Banco de dados (SQLite por padrão, para produção use Postgres/URL fornecida)
# Ex: sqlite:///./data/autodops.db or postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./data/autodops.db
# Para desenvolvimento com Postgres (exemplo local via docker-compose):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/autodops

# Redis (opcional, usado para rate-limiting). Deixe vazio para o fallback em memória.
REDIS_URL=

# Endpoint OTLP (observability) e Sentry/monitoring (opcional)
OTLP_ENDPOINT=
SENTRY_DSN=
